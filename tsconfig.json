{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noEmit": true,
    "rootDir": ".",
    "types": ["node"]
  },
  "include": ["api/**/*.ts", "lib/**/*.ts", "middleware.ts", "tests/**/*.ts"]
}
